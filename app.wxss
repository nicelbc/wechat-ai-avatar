/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 通用容器样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 按钮样式 */
.btn-primary {
  background-color: #07C160;
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin: 20rpx 0;
}

.btn-primary:active {
  background-color: #06AD56;
}

.btn-secondary {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #ddd;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin: 20rpx 0;
}

.btn-secondary:active {
  background-color: #f5f5f5;
}

.btn-danger {
  background-color: #f44336;
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin: 20rpx 0;
}

.btn-danger:active {
  background-color: #d32f2f;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

/* 输入框样式 */
.input {
  background-color: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin: 10rpx 0;
  min-height: 80rpx;
}

.input:focus {
  border-color: #07C160;
}

/* 标签样式 */
.tag {
  display: inline-block;
  background-color: #e8f5e9;
  color: #07C160;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin: 5rpx;
}

.tag-vip {
  background-color: #fff3e0;
  color: #ff9800;
}

.tag-free {
  background-color: #e3f2fd;
  color: #2196f3;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loading-text {
  color: #666;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 图片预览 */
.image-preview {
  width: 100%;
  border-radius: 15rpx;
  margin: 10rpx 0;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
  margin: 10rpx 0;
}

.progress-fill {
  height: 100%;
  background-color: #07C160;
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 提示信息 */
.toast {
  position: fixed;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  z-index: 9999;
  opacity: 0;
  transition: opacity 0.3s;
}

.toast.show {
  opacity: 1;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background-color: white;
  border-radius: 30rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

/* 广告单元 */
.ad-container {
  margin: 20rpx 0;
  border-radius: 15rpx;
  overflow: hidden;
  background-color: #f5f5f5;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

/* VIP特权卡片 */
.vip-card {
  background: linear-gradient(135deg, #ff9800, #ff5722);
  color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
}

.vip-card-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.vip-card-text {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

/* 价格标签 */
.price-tag {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff9800;
}

.price-unit {
  font-size: 24rpx;
  color: #666;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #e0e0e0;
  margin: 20rpx 0;
}

/* 头像样式 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #07C160;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: white;
  border-radius: 15rpx;
  margin: 10rpx 0;
}

.list-item-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999;
}

.list-item-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 网格布局 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-item {
  background-color: white;
  border-radius: 15rpx;
  padding: 20rpx;
  text-align: center;
}

.grid-item-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.grid-item-text {
  font-size: 24rpx;
  color: #333;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.pulse {
  animation: pulse 2s infinite;
}

/* 响应式设计 */
@media (min-width: 750px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }

  .grid {
    grid-template-columns: repeat(3, 1fr);
  }
}