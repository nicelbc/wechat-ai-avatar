/* pages/gallery/gallery.wxss */

/* 过滤器栏 */
.filter-bar {
  margin-bottom: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tags {
  display: flex;
  gap: 10rpx;
  padding: 10rpx 0;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background-color: #f0f0f0;
  padding: 12rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  transition: all 0.2s;
  white-space: nowrap;
}

.filter-tag:active {
  transform: scale(0.95);
}

.filter-tag.active {
  background-color: #07C160;
  color: white;
}

.filter-name {
  font-weight: 500;
}

.filter-count {
  background-color: rgba(255, 255, 255, 0.3);
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
}

.filter-tag.active .filter-count {
  background-color: rgba(255, 255, 255, 0.2);
}

/* 图片网格 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.grid-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 15rpx;
  overflow: hidden;
  background-color: #f0f0f0;
}

.grid-image {
  width: 100%;
  height: 100%;
}

.grid-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 15rpx;
}

.grid-style-tag {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.9);
  color: #333;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 500;
}

/* 图片详情 */
.image-preview-container {
  margin: 20rpx 0;
  background-color: #f8f8f8;
  border-radius: 15rpx;
  padding: 20rpx;
}

.image-preview {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
}

.image-info {
  margin: 20rpx 0;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
}

.info-label {
  font-size: 24rpx;
  color: #666;
  min-width: 80rpx;
}

.info-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  padding: 20rpx;
  display: flex;
  gap: 15rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-bar .btn-secondary,
.action-bar .btn-danger {
  flex: 1;
  margin: 0;
}

/* 模态框大尺寸 */
.modal-large {
  max-width: 85%;
  max-height: 80%;
  overflow-y: auto;
}

/* 响应式设计 */
@media (min-width: 750px) {
  .image-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .modal-large {
    max-width: 70%;
  }
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #666;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 10rpx;
}