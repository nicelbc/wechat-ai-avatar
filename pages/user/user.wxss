/* pages/user/user.wxss */

/* 用户资料 */
.user-profile {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #07C160;
  margin-right: 20rpx;
}

.profile-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 20rpx;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.profile-desc {
  font-size: 24rpx;
  color: #999;
}

.profile-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

/* VIP卡片 */
.vip-card {
  background: linear-gradient(135deg, #ff9800, #ff5722);
  color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
}

.vip-card-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.vip-card-text {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 15rpx;
}

.vip-price {
  margin-bottom: 20rpx;
}

.price-tag {
  font-size: 48rpx;
  font-weight: bold;
}

.price-unit {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 统计数据 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx 10rpx;
  background-color: #f8f8f8;
  border-radius: 15rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07C160;
  display: block;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
}

/* 配额信息 */
.quota-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.quota-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.quota-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.quota-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #07C160;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #07C160;
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 15rpx;
  transition: all 0.2s;
}

.list-item:active {
  background-color: #e8f5e9;
}

.list-item-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999;
}

.list-item-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 按钮区域 */
.action-buttons {
  display: flex;
  gap: 15rpx;
}

.action-buttons .btn-primary,
.action-buttons .btn-secondary {
  flex: 1;
  margin: 0;
}

/* 响应式设计 */
@media (min-width: 750px) {
  .stats-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .quick-actions .list-item {
    margin: 0 auto;
    max-width: 600rpx;
  }
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}