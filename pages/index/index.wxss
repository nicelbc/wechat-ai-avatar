/* pages/index/index.wxss */

/* 用户信息区域 */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999;
}

.user-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

/* 配额信息 */
.quota-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.quota-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.quota-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.quota-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #07C160;
}

/* 功能网格 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-item {
  background-color: #f8f8f8;
  border-radius: 15rpx;
  padding: 25rpx 15rpx;
  text-align: center;
  transition: all 0.2s;
}

.grid-item:active {
  background-color: #e8f5e9;
  transform: scale(0.98);
}

.grid-item-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.grid-item-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.grid-item-desc {
  font-size: 22rpx;
  color: #999;
}

/* 热门风格标签 */
.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.style-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: #f0f0f0;
  padding: 12rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  transition: all 0.2s;
}

.style-tag:active {
  background-color: #e8f5e9;
  transform: scale(0.95);
}

.style-icon {
  font-size: 28rpx;
}

.style-name {
  color: #333;
  font-weight: 500;
}

/* 快捷操作列表 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 15rpx;
  transition: all 0.2s;
}

.list-item:active {
  background-color: #e8f5e9;
}

.list-item-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999;
}

.list-item-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 按钮区域 */
.action-buttons {
  display: flex;
  gap: 15rpx;
}

.action-buttons .btn-primary,
.action-buttons .btn-secondary {
  flex: 1;
  margin: 0;
}

/* VIP卡片 */
.vip-card {
  background: linear-gradient(135deg, #ff9800, #ff5722);
  color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
}

.vip-card-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.vip-card-text {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

/* 响应式设计 */
@media (min-width: 750px) {
  .grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .style-tags {
    justify-content: center;
  }

  .quick-actions .list-item {
    margin: 0 auto;
    max-width: 600rpx;
  }
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.4s ease-out;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #666;
  font-size: 28rpx;
}